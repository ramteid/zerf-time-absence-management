    "jsdom": "^29.1.1",
    "prettier": "^3.9.1",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte": "^5.56.4",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "flatpickr": "^4.6.13"
