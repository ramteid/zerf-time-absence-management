# --- KitaZeit configuration --------------------------------------------------
# 1. Copy to .env:           cp .env.example .env && chmod 600 .env
# 2. Generate secrets:       see README.md "Quick start" for copy-paste commands
# 3. Set your domain/admin e-mail: edit the two lines below

# ── Required ─────────────────────────────────────────────────────────────────

# Your public hostname — Caddy obtains a Let's Encrypt certificate automatically.
KITAZEIT_DOMAIN=example.com

# E-mail for the bootstrap admin account (initial password is "admin").
KITAZEIT_ADMIN_EMAIL=admin@example.com

# Random secret for session-cookie signing (generate with: openssl rand -hex 32).
KITAZEIT_SESSION_SECRET=CHANGE_ME

# Bundled PostgreSQL credentials (generate password with: openssl rand -hex 32).
KITAZEIT_POSTGRES_PASSWORD=CHANGE_ME
KITAZEIT_POSTGRES_DB=kitazeit
KITAZEIT_POSTGRES_USER=kitazeit

# ── Optional ─────────────────────────────────────────────────────────────────

# Backups are executed automatically. Default: every 24h, keep for 30 days. It must be a positive integer.
# BACKUP_INTERVAL_SECONDS=86400
# BACKUP_RETENTION_DAYS=30

# ── SMTP ─────────────────────────────────────────────────────────────────
# Enables outbound e-mail for approvals, rejections, and reopen-request events.
# Leave KITAZEIT_SMTP_HOST unset to disable e-mail; in-app notifications still work.
# KITAZEIT_SMTP_HOST=smtp.example.com
# KITAZEIT_SMTP_PORT=587
# KITAZEIT_SMTP_USERNAME=
# KITAZEIT_SMTP_PASSWORD=
# KITAZEIT_SMTP_FROM="KitaZeit <noreply@example.com>"
# KITAZEIT_SMTP_ENCRYPTION=starttls   # starttls | tls | none
