# --- Release version ------------------------------------------------------
# Controls which images are used when starting the stack.
# Possible values:
#   dev      — always build images locally from the Dockerfiles (no registry pull)
#   latest   — always pull the most recent released image from the registry (default)
#   1.2.3    — pin to a specific released version
ZERF_VERSION=latest

# --- Zerf configuration --------------------------------------------------
# 1. Copy to .env:           cp .env.example .env && chmod 600 .env
# 2. Generate secrets:       see README.md "Quick start" for copy-paste commands
# 3. Set deployment-specific variables below (local vs. public)

# -- REQUIRED TO SET (all deployments) ------------------------------------------------

# Random secret for session-cookie signing (generate with: openssl rand -hex 32).
ZERF_SESSION_SECRET=
ZERF_POSTGRES_PASSWORD=
# Encryption key for data at rest. A single key controls two things:
#   1. gocryptfs AES-256-GCM encryption of the PostgreSQL data directory on disk.
#   2. AES-256-CBC encryption of all automated backup files (.dump.enc).
# Generate with: openssl rand -hex 32
# Keep this safe — losing it makes both the live database and backups unreadable.
ZERF_DB_ENCRYPTION_KEY=
# Choose any name for database name and user
ZERF_POSTGRES_DB=
ZERF_POSTGRES_USER=

# -- Required for public deployment with Caddy (start_public.sh) ---------------
#
# Your public hostname — e.g. "zerf.example.com". This is used for generating the TLS certificate and for CORS configuration.
# ZERF_PUBLIC_URL and ZERF_ALLOWED_ORIGINS are derived from this value automatically.
# Not needed for local deployment (start_local.sh uses http://localhost:3333 internally).
#
ZERF_DOMAIN=

# -- Optional -----------------------------------------------------------------

# Enable debug build: unminified frontend, debug Rust binary, and RUST_BACKTRACE=1.
# Only effective when ZERF_VERSION=dev (local build). Ignored for registry images.
# DEBUG=false

# Backups are executed automatically. Default: every 24h, keep for 30 days. It must be a positive integer.
# BACKUP_INTERVAL_SECONDS=86400
# BACKUP_RETENTION_DAYS=30
