# Version control
.git
.github

# Build artifacts
target
backend/target
node_modules
frontend/node_modules
frontend/dist

# Data and databases
data
*.db
*.db-journal
*.db-wal
*.db-shm

# Environment files
.env
.env.*
!.env.example

# Docker and deployment
docker/*
!docker/Dockerfile
Caddyfile
caddy_data
caddy_config
Dockerfile
.dockerignore

# Documentation
README.md
SECURITY.md
LICENSE

# Tests and scripts
backend/tests
frontend/**/*.test.js
frontend/**/*.test.ts
frontend/**/*.spec.js
frontend/**/*.spec.ts
# Exclude the scripts/ contents but keep the directory traversable and re-include
# backup.sh, which backup.Dockerfile COPYs into the self-contained backup image.
scripts/*
!scripts/backup.sh

# Shell scripts (root-level only; does not match scripts/backup.sh)
*.sh
